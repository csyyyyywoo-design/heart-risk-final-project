# use step AIC to find best model

full_model <- glm(Heart.Attack.Risk..Binary. ~ .,
                  data = heart_nomis,
                  family = binomial)

step_model <- stepAIC(full_model,
                      direction = "both",
                      trace = TRUE)


# See auc and roc of the best model from step aic 

library(pROC)

best_model <- glm(
  Heart.Attack.Risk..Binary. ~ Cholesterol + Sleep.Hours.Per.Day +
    Heart.Attack.Risk..Text. + Systolic.blood.pressure,
  data = data,
  family = binomial
)

pred_probs <- predict(best_model, type = "response")

roc_obj <- roc(data$Heart.Attack.Risk..Binary, pred_probs)

auc(roc_obj)

plot(roc_obj, col = "blue", main = "ROC Curve for Best Logistic Model")
